{
  "databaseChangeLog": [
    {
      "changeSet": {
        "id": "005-user-state-userid-to-bigint",
        "author": "pc",
        "comment": "Migrate user_state.userid from VARCHAR (student userid string) to BIGINT (users.id). Old data is not needed.",
        "changes": [
          { "delete": { "tableName": "user_state" } },
          { "dropColumn": { "tableName": "user_state", "columnName": "userid" } },
          {
            "addColumn": {
              "tableName": "user_state",
              "columns": [
                {
                  "column": {
                    "name": "userid",
                    "type": "BIGINT",
                    "constraints": { "nullable": false, "unique": true }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
